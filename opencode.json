{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "n8n": {
      "type": "remote",
      "url": "https://n8n.srv1000134.hstgr.cloud/mcp-server/http",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:N8N_MCP_TOKEN}"
      }
    },
    "n8n-docs": {
      "type": "remote",
      "url": "https://api.n8n-mcp.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:N8N_API_KEY}"
      }
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "ESLint": {
      "type": "local",
      "command": ["npx", "@eslint/mcp@latest"],
      "enabled": true
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_COPILOT_MCP_TOKEN2}"
      }
    },
    "clerk": {
      "type": "remote",
      "url": "https://mcp.clerk.com/mcp",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "neondatabase/mcp-server-neon": {
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:NEON_API_KEY}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:CONTEXT7_API_KEY}"
      }
    },
    "openaiDeveloperDocs": {
      "type": "remote",
      "url": "https://developers.openai.com/mcp",
      "enabled": true
    },
    "awslabs.s3-tables-mcp-server": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "--from",
        "awslabs.s3-tables-mcp-server@latest",
        "awslabs.s3-tables-mcp-server.exe"
      ],
      "enabled": true,
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "{env:AWS_PROFILE}",
        "AWS_REGION": "{env:AWS_REGION}"
      }
    },
    "snyk": {
      "type": "local",
      "command": ["npx", "-y", "snyk@latest", "mcp", "-t", "stdio"],
      "enabled": true,
      "environment": {
        "SNYK_TOKEN": "{env:SNYK_TOKEN}"
      }
    },
    "Vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    }
  },
  "permission": "allow"
}
